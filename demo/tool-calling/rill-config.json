{
  "name": "tool-calling",
  "version": "0.1.0",
  "main": "scripts/main.rill:handler",
  "description": "Demonstrates LLM tool calling with weather, temperature, and calculator tools",
  "runtime": ">=0.18.0",
  "extensions": {
    "mounts": {
      "llm": { "package": "@rcrsr/rill-ext-openai" }
    },
    "config": {
      "llm": {
        "api_key": "${GROQ_API_KEY}",
        "model": "openai/gpt-oss-20b",
        "base_url": "https://api.groq.com/openai/v1"
      }
    }
  },
  "host": {
    "timeout": 30000
  },
  "deploy": {
    "port": 4003
  }
}
