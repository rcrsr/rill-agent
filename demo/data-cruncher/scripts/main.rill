# Data Cruncher — pipe-based statistics
#
# Params: $numbers (list of numbers)
# Extension: kv (persistent run counter)

# Validate input
$numbers -> assert (.len > 0) "numbers param is required"

# Basic statistics via fold
$numbers -> .len => $count
$numbers -> fold(0) { $@ + $ } => $sum
$sum / $count => $mean

# Min and max
$numbers -> fold($numbers[0]) { ($ < $@) ? $ ! $@ } => $min
$numbers -> fold($numbers[0]) { ($ > $@) ? $ ! $@ } => $max

# Derived collections
$numbers -> filter { $ > $mean } => $above_mean
$numbers -> map { $ * $ } => $squared
$numbers -> map { $ - $mean } -> map { $ * $ } -> fold(0) { $@ + $ } => $variance_sum
$variance_sum / $count => $variance

# Track run count with kv
kv::get_or("default", "runs", 0) => $prev
$prev + 1 => $runs
kv::set("default", "runs", $runs)

# Log for SSE observability
"run {$runs}: crunching {$count} numbers" -> log

# Return result dict
[
  count: $count,
  sum: $sum,
  mean: $mean,
  min: $min,
  max: $max,
  variance: $variance,
  above_mean: $above_mean,
  squared: $squared,
  run_number: $runs
]
