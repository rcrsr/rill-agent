{
  "name": "classifier",
  "version": "0.1.0",
  "main": "../../scripts/classify.rill:handler",
  "description": "Classifies input text by category, topics, language, and confidence",
  "runtime": ">=0.18.0",
  "extensions": {
    "mounts": {
      "llm": { "package": "@rcrsr/rill-ext-openai" }
    },
    "config": {
      "llm": {
        "api_key": "${GROQ_API_KEY}",
        "model": "llama-3.3-70b-versatile",
        "base_url": "https://api.groq.com/openai/v1"
      }
    }
  },
  "host": {
    "maxConcurrency": 5
  }
}
