# Classifier — categorize text by topic, language, and confidence
# Params: $text

$text -> assert (.len > 0) "text param is required"

[
  category: [type: "string", enum: ["technology", "science", "business", "politics", "entertainment", "sports", "health", "other"], description: "Primary content category"],
  topics: [type: "list", items: "string", description: "Up to 5 key topics"],
  language: [type: "string", description: "Detected language code (en, es, fr, etc.)"],
  confidence: [type: "number", description: "Classification confidence from 0 to 1"]
] => $schema

llm::generate("Classify the following text into a category, extract key topics, detect the language, and rate your confidence.\n\nText:\n{$text}", [schema: $schema])
  -> .data
