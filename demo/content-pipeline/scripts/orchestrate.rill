# Orchestrator — fan out to classifier and summarizer, merge results
# Params: $text
# Extensions: ahi (classifier, summarizer)

$text -> assert (.len > 0) "text param is required"

# Call classifier worker
ahi::classifier([text: $text]) => $classification
"classified: category={$classification.category}, confidence={$classification.confidence}" -> log

# Call summarizer worker
ahi::summarizer([text: $text]) => $summary
"summarized: {$summary.key_points.len} key points, {$summary.word_count} words" -> log

# Merge results
[
  classification: $classification,
  summary: $summary
]
