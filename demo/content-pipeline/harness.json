{
  "host": {
    "port": 4002,
    "maxConcurrency": 15
  },
  "shared": {},
  "agents": [
    {
      "name": "classifier",
      "entry": "scripts/classify.rill",
      "maxConcurrency": 5,
      "extensions": {
        "llm": {
          "package": "@rcrsr/rill-ext-openai"
        }
      },
      "input": {
        "text": { "type": "string", "required": true }
      },
      "output": {
        "type": "dict",
        "fields": {
          "category": { "type": "string" },
          "topics": { "type": "list" },
          "language": { "type": "string" },
          "confidence": { "type": "number" }
        }
      }
    },
    {
      "name": "summarizer",
      "entry": "scripts/summarize.rill",
      "maxConcurrency": 5,
      "extensions": {
        "llm": {
          "package": "@rcrsr/rill-ext-openai"
        }
      },
      "input": {
        "text": { "type": "string", "required": true }
      },
      "output": {
        "type": "dict",
        "fields": {
          "summary": { "type": "string" },
          "key_points": { "type": "list" },
          "word_count": { "type": "number" }
        }
      }
    },
    {
      "name": "orchestrator",
      "entry": "scripts/orchestrate.rill",
      "maxConcurrency": 5,
      "extensions": {
        "ahi": {
          "package": "@rcrsr/rill-agent-ext-ahi"
        }
      },
      "input": {
        "text": { "type": "string", "required": true }
      },
      "output": {
        "type": "dict",
        "fields": {
          "classification": { "type": "dict" },
          "summary": { "type": "dict" }
        }
      }
    }
  ]
}
