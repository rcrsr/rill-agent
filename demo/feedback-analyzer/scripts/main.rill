# Feedback Analyzer — structured extraction + response drafting
# Params: $feedback (customer feedback string)
# Extension: llm (OpenAI via generate + message)

# Validate input
$feedback -> assert (.len > 0) "feedback param is required"

# Structured schema for analysis results
shape(
  ^("Overall sentiment", enum: ["positive", "negative", "mixed"]) sentiment: string,
  ^("Specific issues mentioned") issues: list,
  ^("How urgent the feedback is", enum: ["low", "medium", "high"]) urgency: string,
  ^("Feedback category", enum: ["onboarding", "billing", "performance", "support", "other"]) category: string
) => $schema

# Step 1: Extract structured analysis via generate()
llm::generate("Analyze this customer feedback: {$feedback}", [schema: $schema]) => $analysis
  -> .data -> :$schema => $data
  -> "analyzed: sentiment={.sentiment}, urgency={.urgency}, category={.category}" -> log

# Step 2: Draft a response using message()
"""
Write a brief, empathetic customer support response.
Keep it under 3 sentences.

Feedback: {$feedback}
Sentiment: {$data.sentiment}
Issues: {$data.issues}
Urgency: {$data.urgency}
""" 
  -> llm::message($, [system: "You are a helpful customer support agent. Be concise and empathetic."]) => $reply
  -> "response drafted ({.usage.output} tokens)" -> log

# Step 3: Return combined result
[
  sentiment: $data.sentiment,
  issues: $data.issues,
  urgency: $data.urgency,
  category: $data.category,
  response: $reply.content,
  usage: [
    analysis_tokens: $analysis.usage.input + $analysis.usage.output,
    response_tokens: $reply.usage.input + $reply.usage.output
  ]
]
