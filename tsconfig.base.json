{
  "compilerOptions": {
    // Language & Environment
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    // Output
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // Strict Type Checking
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Module Handling
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,

    // Code Quality
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,

    // Consistency
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // Composite for project references
    "composite": true,

    // Path mappings for agent packages
    "paths": {
      "@rcrsr/rill-agent-shared": ["./packages/agent/shared/src/index.ts"],
      "@rcrsr/rill-agent-registry": ["./packages/agent/registry/src/index.ts"],
      "@rcrsr/rill-agent-ext-ahi": ["./packages/agent/ahi/src/index.ts"],
      "@rcrsr/rill-agent-harness": ["./packages/agent/harness/src/index.ts"],
      "@rcrsr/rill-agent-bundle": ["./packages/agent/bundle/src/index.ts"],
      "@rcrsr/rill-agent-run": ["./packages/agent/run/src/index.ts"]
    }
  }
}
