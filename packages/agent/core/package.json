{
  "name": "@rcrsr/rill-agent",
  "version": "0.18.4",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/harness/http.d.ts",
      "default": "./dist/harness/http.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
