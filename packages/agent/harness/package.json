{
  "name": "@rcrsr/rill-agent-harness",
  "version": "0.18.4",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "default": "./dist/http/index.js"
    },
    "./stdio": {
      "types": "./dist/stdio/index.d.ts",
      "default": "./dist/stdio/index.js"
    },
    "./gateway": {
      "types": "./dist/gateway/index.d.ts",
      "default": "./dist/gateway/index.js"
    },
    "./worker": {
      "types": "./dist/worker/index.d.ts",
      "default": "./dist/worker/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --config ../../../eslint.config.js src/",
    "check": "pnpm run build && pnpm run test && pnpm run lint"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@rcrsr/rill": "^0.18.4",
    "@rcrsr/rill-agent-shared": "workspace:^",
    "@rcrsr/rill-config": "^0.18.4",
    "esbuild": "^0.28.0",
    "hono": "^4.12.10",
    "prom-client": "^15.1.3"
  },
  "optionalDependencies": {
    "@rcrsr/rill-agent-registry": "workspace:^"
  },
  "devDependencies": {
    "@rcrsr/rill-agent-ext-ahi": "workspace:^"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rcrsr/rill-agent.git",
    "directory": "packages/agent/harness"
  }
}
